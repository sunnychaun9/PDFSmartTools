<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Default: trust system CAs, disable cleartext -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext for React Native Metro bundler in debug only -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>

    <!-- Pin Google Play Billing API domains -->
    <domain-config>
        <domain includeSubdomains="true">play.googleapis.com</domain>
        <domain includeSubdomains="true">android.googleapis.com</domain>
        <domain includeSubdomains="true">firebaseinstallations.googleapis.com</domain>
        <domain includeSubdomains="true">firebaselogging.googleapis.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
